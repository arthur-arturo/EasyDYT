{
  "manifest_version": 3,
  "name": "EasyDYT",
  "version": "1.1",
  "description": "Easy Download for YouTube. Descarga videos y Shorts de YouTube a MP3 (320kbps) y MP4 (Video Max Calidad) con un solo clic sin anuncios.",
  "permissions": [
    "downloads",
    "storage"
  ],
  "host_permissions": [
    "*://*.youtube.com/*",
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.youtube.com/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "content.css"
      ],
      "run_at": "document_end"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Configuración de Descarga"
  }
}
